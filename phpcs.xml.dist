<?xml version="1.0"?>
<ruleset>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="p"/> <!-- progress -->
    <arg value="s"/> <!-- show sniff error codes -->

    <!-- Default paths to cover -->
    <file>src</file>
    <file>tests</file>

    <rule ref="PSR12"/>
</ruleset>
